}
# Best model submission (default)
best_predictions <- if (best_model_name %in% names(predictions_list)) {
predictions_list[[best_model_name]]
} else if (length(predictions_list) > 0) {
predictions_list[[1]]
} else {
stop("ERROR: No predictions available!")
}
submission_best <- data.frame(
Customer.ID = test_customer_ids,
Predicted_Status = best_predictions
)
write.csv(submission_best, file.path(PROJECT_DIR, "submission_test_predictions.csv"),
row.names = FALSE)

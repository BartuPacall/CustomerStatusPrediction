bad_indices <- is.na(test_final[[col]]) | is.nan(test_final[[col]]) | is.infinite(test_final[[col]])
if (any(bad_indices)) {
if (col %in% names(train_medians) && !is.na(train_medians[col])) {
fill_value <- train_medians[col]
} else {
fill_value <- median(test_final[[col]][!bad_indices], na.rm = TRUE)
if (is.na(fill_value) || is.nan(fill_value) || is.infinite(fill_value)) {
fill_value <- 0
}
}
test_final[[col]][bad_indices] <- fill_value
}
}
}
}
na_count_after <- sum(is.na(test_final))
nan_count_after <- sum(sapply(test_final, function(x) sum(is.nan(x))))
inf_count_after <- sum(sapply(test_final, function(x) sum(is.infinite(x))))
cat("  - Problems after fix: NA=", na_count_after, " NaN=", nan_count_after,
" Inf=", inf_count_after, "\n", sep = "")
if (na_count_after + nan_count_after + inf_count_after > 0) {
stop("ERROR: Still have problematic values after fix!")
}
cat("DONE: Test model prepared and cleaned.\n")
## =========================================================
## 10) PREDICTIONS FOR ALL MODELS
## =========================================================
cat("\n[10/10] GENERATING PREDICTIONS...\n")
predictions_list <- list()
# Random Forest
if (models_available$rf) {
cat("  - Random Forest...\n")
tryCatch({
pred_rf <- predict(rf_model, newdata = test_final)
predictions_list$rf <- pred_rf
cat("    * Success: ", length(pred_rf), " predictions\n", sep = "")
}, error = function(e) {
cat("    * ERROR:", e$message, "\n")
})
}
# Logistic Regression
if (models_available$log) {
cat("  - Logistic Regression...\n")
tryCatch({
pred_log <- predict(log_model, newdata = test_final)
predictions_list$log <- pred_log
cat("    * Success: ", length(pred_log), " predictions\n", sep = "")
}, error = function(e) {
cat("    * ERROR:", e$message, "\n")
})
}
# GBM
if (models_available$gbm) {
cat("  - GBM...\n")
tryCatch({
pred_gbm <- predict(gbm_model, newdata = test_final)
predictions_list$gbm <- pred_gbm
cat("    * Success: ", length(pred_gbm), " predictions\n", sep = "")
}, error = function(e) {
cat("    * ERROR:", e$message, "\n")
})
}
# VERIFY PREDICTION COUNTS
for (model_name in names(predictions_list)) {
pred_len <- length(predictions_list[[model_name]])
if (pred_len != nrow(master_test)) {
stop("CRITICAL ERROR: ", toupper(model_name), " prediction count mismatch!\n",
"Expected: ", nrow(master_test), " | Got: ", pred_len)
}
}
cat("  - All predictions verified: ", nrow(master_test), " rows\n", sep = "")
cat("DONE: Predictions generated for all models.\n")
## =========================================================
## 11) ALWAYS CREATE PREDICTION DISTRIBUTION VISUALIZATIONS
## =========================================================
cat("\n========================================================\n")
cat("CREATING PREDICTION DISTRIBUTION VISUALIZATIONS\n")
cat("========================================================\n")
# Create prediction distribution table and chart for each model
for (model_name in names(predictions_list)) {
preds <- predictions_list[[model_name]]
pred_table <- as.data.frame(table(preds))
colnames(pred_table) <- c("Status", "Count")
pred_table$Percentage <- round(100 * pred_table$Count / sum(pred_table$Count), 2)
# Save table
write.csv(pred_table,
file.path(PROJECT_DIR, paste0("prediction_distribution_", model_name, ".csv")),
row.names = FALSE)
# Create bar chart
p_dist <- ggplot(pred_table, aes(x = Status, y = Count, fill = Status)) +
geom_bar(stat = "identity", width = 0.7) +
geom_text(aes(label = paste0(Count, "\n(", Percentage, "%)")),
vjust = -0.3, size = 4) +
scale_fill_brewer(palette = "Set2") +
labs(
title = paste("Prediction Distribution -", toupper(model_name)),
subtitle = paste("Total Predictions:", sum(pred_table$Count)),
x = "Predicted Status",
y = "Count"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold", size = 14),
plot.subtitle = element_text(hjust = 0.5, size = 12),
legend.position = "none"
)
ggsave(file.path(PROJECT_DIR, paste0("prediction_distribution_", model_name, ".png")),
plot = p_dist, width = 10, height = 7)
cat("  - Created: prediction_distribution_", model_name, ".png\n", sep = "")
}
# Create comparison of prediction distributions across models
if (length(predictions_list) > 1) {
all_preds <- data.frame()
for (model_name in names(predictions_list)) {
temp_df <- data.frame(
Model = toupper(model_name),
Status = predictions_list[[model_name]]
)
all_preds <- rbind(all_preds, temp_df)
}
pred_comparison <- all_preds %>%
group_by(Model, Status) %>%
summarise(Count = n(), .groups = "drop") %>%
group_by(Model) %>%
mutate(Percentage = round(100 * Count / sum(Count), 2))
# Save comparison table
write.csv(pred_comparison,
file.path(PROJECT_DIR, "prediction_comparison_all_models.csv"),
row.names = FALSE)
# Create comparison chart
p_compare <- ggplot(pred_comparison, aes(x = Status, y = Count, fill = Model)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.8), width = 0.7) +
geom_text(aes(label = Count),
position = position_dodge(width = 0.8), vjust = -0.5, size = 3) +
scale_fill_brewer(palette = "Set1") +
labs(
title = "Prediction Comparison Across Models",
subtitle = paste("Total Customers:", nrow(master_test)),
x = "Predicted Status",
y = "Count",
fill = "Model"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold", size = 14),
plot.subtitle = element_text(hjust = 0.5, size = 12),
legend.position = "top"
)
ggsave(file.path(PROJECT_DIR, "prediction_comparison_all_models.png"),
plot = p_compare, width = 12, height = 7)
cat("  - Created: prediction_comparison_all_models.png\n")
}
## =========================================================
## 12) EVALUATION (IF GROUND TRUTH EXISTS)
## =========================================================
if (has_ground_truth) {
cat("\n========================================================\n")
cat("MODEL EVALUATION WITH GROUND TRUTH\n")
cat("========================================================\n")
# Initialize results dataframe
eval_results <- data.frame(
Model = character(),
Accuracy = numeric(),
Kappa = numeric(),
Balanced_Accuracy = numeric(),
Macro_F1 = numeric(),
stringsAsFactors = FALSE
)
confusion_matrices <- list()
# Evaluate each model
for (model_name in names(predictions_list)) {
cat("\n--- Evaluating", toupper(model_name), "---\n")
preds <- predictions_list[[model_name]]
cm <- confusionMatrix(preds, test_ground_truth)
confusion_matrices[[model_name]] <- cm
# Extract metrics
accuracy <- cm$overall["Accuracy"]
kappa <- cm$overall["Kappa"]
balanced_acc <- if ("Balanced Accuracy" %in% names(cm$byClass)) {
mean(cm$byClass[, "Balanced Accuracy"], na.rm = TRUE)
} else {
NA
}
macro_f1 <- calculate_macro_f1(cm)
# Add to results
eval_results <- rbind(eval_results, data.frame(
Model = toupper(model_name),
Accuracy = accuracy,
Kappa = kappa,
Balanced_Accuracy = balanced_acc,
Macro_F1 = macro_f1,
stringsAsFactors = FALSE
))
# Print metrics
cat("Accuracy:", round(accuracy, 4), "\n")
cat("Kappa:", round(kappa, 4), "\n")
cat("Balanced Accuracy:", round(balanced_acc, 4), "\n")
cat("Macro F1:", round(macro_f1, 4), "\n")
# Per-class recall
recalls <- extract_recalls(cm)
if (length(recalls) > 0) {
cat("Per-class Recall:\n")
for (class_name in names(recalls)) {
cat("  ", class_name, ": ", round(recalls[[class_name]], 4), "\n", sep = "")
eval_results[nrow(eval_results), paste0("Recall_", class_name)] <- recalls[[class_name]]
}
}
cat("\nConfusion Matrix:\n")
print(cm$table)
}
# Save evaluation results
write.csv(eval_results, file.path(PROJECT_DIR, "test_model_comparison_metrics.csv"),
row.names = FALSE)
cat("\nSaved: test_model_comparison_metrics.csv\n")
## =========================================================
## 13) VISUALIZATION - CONFUSION MATRICES
## =========================================================
cat("\n--- Creating Confusion Matrix Heatmaps ---\n")
for (model_name in names(confusion_matrices)) {
cm <- confusion_matrices[[model_name]]
cm_table <- as.data.frame(cm$table)
# Calculate percentages
cm_table <- cm_table %>%
group_by(Reference) %>%
mutate(Percentage = round(100 * Freq / sum(Freq), 1)) %>%
ungroup()
p <- ggplot(cm_table, aes(x = Reference, y = Prediction, fill = Freq)) +
geom_tile(color = "white", size = 1.5) +
geom_text(aes(label = paste0(Freq, "\n(", Percentage, "%)")),
color = "black", size = 4.5, fontface = "bold") +
scale_fill_gradient(low = "lightblue", high = "darkblue") +
labs(
title = paste("Confusion Matrix -", toupper(model_name)),
subtitle = paste("Accuracy:", round(cm$overall["Accuracy"], 4)),
x = "Actual Status",
y = "Predicted Status",
fill = "Count"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold", size = 16),
plot.subtitle = element_text(hjust = 0.5, size = 12),
axis.text = element_text(size = 11, face = "bold"),
axis.title = element_text(size = 12, face = "bold"),
legend.position = "right"
)
filename <- file.path(PROJECT_DIR, paste0("confusion_matrix_", model_name, ".png"))
ggsave(filename, plot = p, width = 10, height = 8, dpi = 300)
cat("  - Saved:", basename(filename), "\n")
}
## =========================================================
## 14) VISUALIZATION - METRIC COMPARISONS
## =========================================================
cat("\n--- Creating Metric Comparison Charts ---\n")
# Accuracy & Kappa comparison
metrics_long <- eval_results %>%
select(Model, Accuracy, Kappa) %>%
pivot_longer(cols = c(Accuracy, Kappa), names_to = "Metric", values_to = "Value")
p_acc_kappa <- ggplot(metrics_long, aes(x = Model, y = Value, fill = Metric)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.8), width = 0.7) +
geom_text(aes(label = sprintf("%.4f", Value)),
position = position_dodge(width = 0.8), vjust = -0.5, size = 4, fontface = "bold") +
scale_fill_manual(values = c("Accuracy" = "steelblue", "Kappa" = "coral")) +
labs(
title = "Model Comparison: Accuracy & Kappa",
subtitle = "Higher is Better",
x = "Model",
y = "Score",
fill = "Metric"
) +
ylim(0, 1.1) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold", size = 16),
plot.subtitle = element_text(hjust = 0.5, size = 12),
axis.text = element_text(size = 11),
axis.title = element_text(size = 12, face = "bold"),
legend.position = "top",
legend.text = element_text(size = 11)
)

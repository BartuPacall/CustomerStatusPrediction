## 16) SUMMARY METRICS TABLE VISUALIZATION
## =========================================================
cat("\n--- Creating Summary Metrics Table ---\n")
# Create a nice table visualization
metrics_display <- eval_results %>%
select(Model, Accuracy, Kappa, Balanced_Accuracy, Macro_F1) %>%
mutate(across(where(is.numeric), ~round(., 4)))
# Convert to long format for heatmap
metrics_heatmap <- metrics_display %>%
pivot_longer(cols = -Model, names_to = "Metric", values_to = "Value")
p_heatmap <- ggplot(metrics_heatmap, aes(x = Metric, y = Model, fill = Value)) +
geom_tile(color = "white", size = 1.5) +
geom_text(aes(label = sprintf("%.4f", Value)),
color = "black", size = 5, fontface = "bold") +
scale_fill_gradient2(low = "red", mid = "yellow", high = "green",
midpoint = 0.5, limits = c(0, 1)) +
labs(
title = "Model Performance Heatmap",
subtitle = "All Key Metrics Comparison",
x = "Metric",
y = "Model",
fill = "Score"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold", size = 16),
plot.subtitle = element_text(hjust = 0.5, size = 12),
axis.text = element_text(size = 11, face = "bold"),
axis.title = element_text(size = 12, face = "bold"),
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "right"
)
ggsave(file.path(PROJECT_DIR, "model_performance_heatmap.png"),
plot = p_heatmap, width = 12, height = 8, dpi = 300)
cat("  - Saved: model_performance_heatmap.png\n")

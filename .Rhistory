geom_text(aes(label = sprintf("%.4f", Value)),
position = position_dodge(width = 0.8), vjust = -0.5, size = 4, fontface = "bold") +
scale_fill_manual(values = c("Balanced_Accuracy" = "lightgreen", "Macro_F1" = "gold")) +

title = "Model Comparison: Balanced Accuracy & Macro F1",
subtitle = "Higher is Better",
x = "Model",
y = "Score",
fill = "Metric"
) +
ylim(0, 1.1) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold", size = 16),
plot.subtitle = element_text(hjust = 0.5, size = 12),
axis.text = element_text(size = 11),
axis.title = element_text(size = 12, face = "bold"),
legend.position = "top",
legend.text = element_text(size = 11)
)
ggsave(file.path(PROJECT_DIR, "comparison_f1_balanced_accuracy.png"),
plot = p_f1_bal, width = 12, height = 8, dpi = 300)
cat("  - Saved: comparison_f1_balanced_accuracy.png\n")
## =========================================================
## 15) ADDITIONAL VISUALIZATION - PER-CLASS RECALL
## =========================================================
cat("\n--- Creating Per-Class Recall Chart ---\n")
# Extract recall columns
recall_cols <- grep("^Recall_", colnames(eval_results), value = TRUE)
if (length(recall_cols) > 0) {
recall_long <- eval_results %>%
select(Model, all_of(recall_cols)) %>%
pivot_longer(cols = all_of(recall_cols), names_to = "Class", values_to = "Recall") %>%
mutate(Class = gsub("Recall_", "", Class))
p_recall <- ggplot(recall_long, aes(x = Class, y = Recall, fill = Model)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.8), width = 0.7) +
geom_text(aes(label = sprintf("%.4f", Recall)),
position = position_dodge(width = 0.8), vjust = -0.5, size = 3.5, fontface = "bold") +
scale_fill_brewer(palette = "Set2") +
labs(
title = "Per-Class Recall Comparison",
subtitle = "Sensitivity by Class and Model",
x = "Class",
y = "Recall (Sensitivity)",
fill = "Model"
) +
ylim(0, 1.1) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold", size = 16),
plot.subtitle = element_text(hjust = 0.5, size = 12),
legend.position = "top",
axis.text.x = element_text(angle = 45, hjust = 1, size = 11),
axis.title = element_text(size = 12, face = "bold"),
legend.text = element_text(size = 11)
)
ggsave(file.path(PROJECT_DIR, "comparison_per_class_recall.png"),
plot = p_recall, width = 12, height = 8, dpi = 300)
cat("  - Saved: comparison_per_class_recall.png\n")
}
